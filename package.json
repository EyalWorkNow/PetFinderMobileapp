{
  "name": "petfind",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.6.1",
  "scripts": {
    "dev": "concurrently \"pnpm --filter @petfind/api dev\" \"pnpm --filter @petfind/mobile dev\"",
    "dev:tunnel": "concurrently \"pnpm --filter @petfind/api dev\" \"pnpm --filter @petfind/mobile dev:tunnel\"",
    "dev:api": "pnpm --filter @petfind/api dev",
    "dev:mobile": "pnpm --filter @petfind/mobile dev",
    "build": "pnpm -r build",
    "lint": "pnpm lint:eslint && pnpm -r lint",
    "lint:eslint": "eslint .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "seed": "pnpm --filter @petfind/api seed"
  },
  "devDependencies": {
    "@types/node": "^22.13.9",
    "concurrently": "^9.1.2",
    "eslint": "^9.36.0",
    "prettier": "^3.6.2",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.44.1"
  }
}