NODE_ENV=development
PORT=4000
API_ORIGIN=*

# Optional: if unset, API runs with in-memory repository
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/petfind

# Supabase Auth/JWT verification
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_JWT_AUDIENCE=authenticated

# Embeddings
EMBEDDING_PROVIDER=auto
OPENAI_API_KEY=
EMBEDDING_DIM=1536

# Notifications / rate limits
EXPO_PUSH_ENABLED=true
PUSH_MAX_PER_DAY=3
MAX_POSTS_PER_HOUR=10
MAX_CONTACTS_PER_HOUR=20

# Local developer fallback auth and auto-seeding
DEV_AUTH_BYPASS=true
AUTO_SEED_DEMO=true
