EXPO_PUBLIC_API_URL=http://localhost:4000

# Optional for real Supabase Auth; leave blank for local demo mode
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# To enable Google sign-in, turn on the Google provider in Supabase Auth and add
# your Expo dev callback URL plus `petfinder://auth/callback` to Supabase Redirect URLs.

# Optional Google Places key (MVP currently uses fallback text label input)
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=
