{
  "expo": {
    "name": "PetFinder",
    "slug": "petfinder",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A4A72"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "petfinder",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "package": "com.petfind.mobile"
    },
    "plugins": [
      "@react-native-firebase/app",
      "expo-notifications",
      "expo-asset",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "petfind-local"
      }
    }
  }
}