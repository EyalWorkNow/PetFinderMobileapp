{
  "expo": {
    "name": "PetFind",
    "slug": "petfind",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A4A72"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.petfind.mobile"
    },
    "android": {
      "package": "com.petfind.mobile"
    },
    "plugins": [
      "expo-notifications",
      "expo-asset",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "petfind-local"
      }
    }
  }
}
